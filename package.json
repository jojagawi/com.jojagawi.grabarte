{
  "name": "grab-arte",
  "version": "1.0.0",
  "private": true,
  "description": "grab-arte",
  "author": "Jorge Garduño",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "develop": "gatsby develop",
    "start": "gatsby develop",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "util:generate_sqllite_interfaces": "pnpm graphql-codegen",
    "test:typecheck": "tsc --noEmit",
    "test:lint": "eslint .",
    "test:style:check": "stylelint \"src/**/*.{scss,css}\"",
    "test:style:fix": "stylelint --fix \"src/**/*.{scss,css}\"",
    "test:format:fix": "prettier --write \"src/**/*.{js,jsx,css,scss}\" \"*.{js,json,md}\"",
    "test:format:check": "prettier --check \"src/**/*.{js,jsx,css,scss}\" \"*.{js,json,md}\"",
    "test:lighthouse": "lhci autorun",
    "test:all": "run-s test:style:check test:format:check ",
    "test:all_": "run-s test:lint test:style:check test:format:check test:typecheck",
    "ci": "run-s test:all build test:lighthouse",
    "ci_": "run-s test:all build test:lighthouse"
  },
